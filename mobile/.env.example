# Konfigurasi URL API Backend

# Jika menggunakan Real Device (USB/WiFi) atau Web, ganti dengan IP lokal komputer Anda (contoh: 192.168.1.10):
# API_URL=http://192.168.x.x:8000/api

# Jika menggunakan iOS Simulator:
# API_URL=http://localhost:8000/api

# Jika menggunakan Android Emulator (default 10.0.2.2 mengarah ke localhost host):
API_URL=http://10.0.2.2:8000/api
